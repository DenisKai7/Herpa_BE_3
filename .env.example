APP_NAME=Herpa Agentic GraphRAG Backend
APP_ENV=development
APP_DEBUG=false
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGINS=http://localhost:3000
ALLOW_MOCK_SERVICES=false

SUPABASE_URL=https://qemidlrgqeumjblthvvp.supabase.co
SUPABASE_PUBLISHABLE_KEY=<SUPABASE_PUBLISHABLE_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>
SUPABASE_JWKS_URL=https://qemidlrgqeumjblthvvp.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
DATABASE_URL=postgresql://postgres:<SUPABASE_DB_PASSWORD>@db.qemidlrgqeumjblthvvp.supabase.co:5432/postgres
DATABASE_POOLER_URL=postgresql://postgres.qemidlrgqeumjblthvvp:<SUPABASE_DB_PASSWORD>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

NEO4J_URI=neo4j+s://a96f5699.databases.neo4j.io
NEO4J_USERNAME=a96f5699
NEO4J_PASSWORD=<NEO4J_PASSWORD>
NEO4J_DATABASE=neo4j
NEO4J_QUERY_TIMEOUT_SECONDS=15

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=<MINIO_ACCESS_KEY>
MINIO_SECRET_KEY=<MINIO_SECRET_KEY>
MINIO_SECURE=false
MINIO_PROFILE_BUCKET=profile-images
MINIO_ATTACHMENT_BUCKET=chat-attachments
MINIO_EXPORT_BUCKET=generated-exports
MINIO_TEMP_BUCKET=processing-temp

LLAMA_CPP_SERVER_IMAGE=ghcr.io/ggml-org/llama.cpp:server
LLAMA_CPP_CUDA_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
LLAMA_TEXT_BASE_URL=http://127.0.0.1:8080/v1
LLAMA_TEXT_MODEL_NAME=Qwen3-4B-Instruct-2507
TEXT_MODEL_PATH=/models/Qwen_Qwen3-4B-Instruct-2507-Q6_K.gguf
TEXT_MODEL_TIMEOUT_SECONDS=180
TEXT_MODEL_CONTEXT_SIZE=4096
TEXT_MODEL_CONTEXT_SAFETY_MARGIN=512
TEXT_MODEL_AUTO_DISCOVER=true
TEXT_MODEL_CIRCUIT_FAILURE_THRESHOLD=3
TEXT_MODEL_CIRCUIT_RESET_SECONDS=20
TEXT_MODEL_GPU_LAYERS=0
TEXT_MODEL_THREADS=8
TEXT_MODEL_PARALLEL=1

FAST_MEDIUM_TEMPERATURE=0.20
FAST_MEDIUM_TOP_P=0.85
FAST_MEDIUM_TOP_K=20
FAST_MEDIUM_MIN_P=0.05
FAST_MEDIUM_REPEAT_PENALTY=1.05
FAST_MEDIUM_MAX_TOKENS=600
FAST_MEDIUM_RETRIEVAL_LIMIT=6

THINKING_HARD_TEMPERATURE=0.25
THINKING_HARD_TOP_P=0.90
THINKING_HARD_TOP_K=30
THINKING_HARD_MIN_P=0.02
THINKING_HARD_REPEAT_PENALTY=1.08
THINKING_HARD_MAX_TOKENS=1000
THINKING_HARD_REFINEMENT_MAX_TOKENS=900
THINKING_HARD_RETRIEVAL_LIMIT=12

LLAMA_VISION_BASE_URL=http://127.0.0.1:8081/v1
LLAMA_VISION_MODEL_NAME=Qwen3-VL-4B-Instruct
VISION_MODEL_PATH=/models/Qwen3-VL-4B-Instruct-Q4_K_M.gguf
VISION_MMPROJ_PATH=/models/mmproj-Qwen3VL-4B-Instruct-Q8_0.gguf
VISION_MODEL_CONTEXT_SIZE=8192
VISION_MODEL_GPU_LAYERS=0
VISION_MODEL_THREADS=8
VISION_MODEL_PARALLEL=1
VISION_MODEL_TIMEOUT_SECONDS=240

AI_RUNTIME_MODE=text
ENABLE_VISION=false
ENABLE_PUBMED=true
ENABLE_PUBCHEM=true
MAX_AGENT_STEPS=12
MAX_TOOL_CALLS=6
MAX_RETRIEVAL_ITEMS=20
MAX_GRAPH_DEPTH=3

NCBI_API_KEY=
NCBI_TOOL_EMAIL=<CONTACT_EMAIL>
NCBI_TOOL_NAME=herpa-agentic-ai

MAX_UPLOAD_SIZE_MB=25
MAX_PDF_PAGES=50
MAX_IMAGE_DIMENSION=4096
MAX_DOCUMENT_CHARACTERS=200000
PRESIGNED_URL_EXPIRY_SECONDS=900
RATE_LIMIT_CHAT_PER_MINUTE=10
RATE_LIMIT_UPLOAD_PER_MINUTE=5
SHARE_TOKEN_EXPIRY_DAYS=30
LOG_LEVEL=INFO
